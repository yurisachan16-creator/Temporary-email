{
  "manifest_version": 2,
  "name": "TempMail+",
  "version": "2.0.2",
  "description": "快速生成临时邮箱，保护您的真实邮件地址",

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "TempMail+",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs",
    "https://www.1secmail.com/*",
    "https://api.mail.tm/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "109.0"
    }
  }
}
