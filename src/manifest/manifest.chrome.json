{
  "manifest_version": 3,
  "name": "TempMail+",
  "version": "2.1.0",
  "description": "快速生成临时邮箱，保护您的真实邮件地址",

  "action": {
    "default_title": "TempMail+",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs",
    "windows"
  ],

  "host_permissions": [
    "https://www.1secmail.com/*",
    "https://api.mail.tm/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
