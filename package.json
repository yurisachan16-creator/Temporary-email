{
  "name": "tempmail-plus",
  "version": "2.0.2",
  "description": "临时邮箱浏览器插件 - TempMail+",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "generate:icons": "node scripts/generate-icons.js",
    "copy:libs": "node scripts/copy-libs.js",
